# ─────────────────────────────────────────────────────────────
# Zupee Drama AI Companion — Environment Config
# ─────────────────────────────────────────────────────────────

# App settings
APP_NAME="Zupee Drama AI Companion"
APP_VERSION="2.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ─── Cohere ───────────────────────────────────────────────
COHERE_API_KEY="Your-Cohere-API-Key-Here"  # ← replace with your actual API key
COHERE_MODEL=command-a-03-2025   # ← updated from command-r-plus
MAX_TOKENS=512
TEMPERATURE=0.85

# ─── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── RAG settings ─────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
TOP_K_RETRIEVAL=5

# ─── Paths ────────────────────────────────────────────────────
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
VECTOR_STORE_DIR=data/processed/vector_stores
MEMORY_STORE_DIR=data/memory_store

# ─── Features ─────────────────────────────────────────────────
SPOILER_PROTECTION_ENABLED=true
MEMORY_ENABLED=true
MEMORY_MAX_TURNS=20
MEMORY_SUMMARY_THRESHOLD=10
INTENT_ENABLED=true